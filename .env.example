# ──────────────────────────────────────────────
# Email 通知設定
# ──────────────────────────────────────────────
EMAIL_SENDER=your_gmail@gmail.com
# Gmail 應用程式密碼 (非登入密碼)，請至 Google 帳戶 > 安全性 > 應用程式密碼 取得
EMAIL_APP_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ──────────────────────────────────────────────
# 富邦 Neo API 設定
# ──────────────────────────────────────────────
FUBON_ACCOUNT=your_fubon_account
FUBON_PASSWORD=your_fubon_password
FUBON_CERT_PATH=C:/path/to/your/cert.pfx

